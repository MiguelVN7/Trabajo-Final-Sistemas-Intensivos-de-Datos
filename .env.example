# =============================================================================
# ST1630 — Variables de entorno (plantilla sin secretos reales)
# Copiar a .env y completar con valores reales antes de levantar.
# =============================================================================

# MinIO — Object Storage
MINIO_ROOT_USER=<usuario-admin>
MINIO_ROOT_PASSWORD=<contraseña-segura>
MINIO_BUCKET=lakehouse

# Kafka KRaft — CLUSTER_ID debe ser base64url de 16 bytes (22 chars)
# Generar con: python3 -c "import base64, uuid; print(base64.urlsafe_b64encode(uuid.uuid4().bytes).decode().rstrip('='))"
KAFKA_CLUSTER_ID=<base64url-22-chars>

# MongoDB
MONGO_ROOT_USER=<usuario-root>
MONGO_ROOT_PASSWORD=<contraseña-segura>
